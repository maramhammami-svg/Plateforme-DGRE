# Copier en .env (non committe, voir .gitignore) et remplacer les valeurs.
# Generer des secrets forts, par ex. : python3 -c "import secrets; print(secrets.token_hex(32))"
POSTGRES_PASSWORD=remplacer-par-un-secret-genere
JWT_SECRET=remplacer-par-un-secret-genere
JWT_EXPIRE_MINUTES=120
# /docs, /redoc, /openapi.json desactives par defaut (surface API publique sinon).
# Mettre a true en dev local si besoin de Swagger UI.
ENABLE_DOCS=false
